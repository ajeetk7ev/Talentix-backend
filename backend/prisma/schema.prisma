// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ================= ENUMS =================

enum Role {
  USER
  RECRUITER
  ADMIN
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum ApplicationStatus {
  APPLIED
  IN_REVIEW
  REJECTED
  ACCEPTED
}

enum VoteType {
  UP
  DOWN
}

enum ReportReason {
  SCAM
  EXPIRED
  MISLEADING
  OTHER
}

// ================= USER =================

model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String?
  role       Role    @default(USER)
  isVerified Boolean @default(false)

  profile          Profile?
  jobs             Job[]         @relation("PostedJobs")
  applications     Application[]
  comments         Comment[]
  votes            Vote[]
  reports          Report[]
  resumes          Resume[]
  jobMatches       JobMatch[]
  savedJobs        SavedJob[]
  chatsAsRecruiter ChatRoom[]    @relation("RecruiterChats")
  chatsAsCandidate ChatRoom[]    @relation("CandidateChats")
  sentMessages     Message[]     @relation("SentMessages")

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  notifications Notification[]
}

// ================= PROFILE =================

model Profile {
  id                String   @id @default(uuid())
  userId            String   @unique
  bio               String?
  location          String?
  skills            String[]
  experience        Int?
  github            String?
  linkedin          String?
  portfolio         String?
  preferredLocation String[]
  education         String?
  currentSalary     Int?
  expectedSalary    Int?
  noticePeriod      String?
  avatar            String?

  workExperiences WorkExperience[]

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ================= WORK EXPERIENCE =================

model WorkExperience {
  id          String    @id @default(uuid())
  profileId   String
  company     String
  role        String
  startDate   DateTime
  endDate     DateTime?
  description String?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// ================= COMPANY =================

model Company {
  id       String  @id @default(uuid())
  name     String
  logo     String?
  about    String?
  website  String?
  location String?

  recruiters User[]
  jobs       Job[]

  createdAt DateTime @default(now())
}

// ================= JOB =================

model Job {
  id          String   @id @default(uuid())
  title       String
  description String
  company     String
  companyId   String?
  companyRef  Company? @relation(fields: [companyId], references: [id])
  location    String
  salaryMin   Int?
  salaryMax   Int?
  jobType     JobType
  isRemote    Boolean  @default(false)

  postedById String
  postedBy   User   @relation("PostedJobs", fields: [postedById], references: [id])

  isCommunityPost Boolean @default(false)
  sourceUrl       String?

  votes        Vote[]
  comments     Comment[]
  reports      Report[]
  applications Application[]
  skills       JobSkill[]
  jobMatches   JobMatch[]
  savedBy      SavedJob[]

  isVerified Boolean   @default(false)
  isExpired  Boolean   @default(false)
  expiresAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([location])
  @@index([jobType])
}

// ================= JOB SKILLS =================

model JobSkill {
  id    String @id @default(uuid())
  jobId String
  skill String

  job Job @relation(fields: [jobId], references: [id])

  @@index([skill])
}

// ================= APPLICATION =================

model Application {
  id     String @id @default(uuid())
  userId String
  jobId  String

  status   ApplicationStatus @default(APPLIED)
  resumeId String?

  user   User    @relation(fields: [userId], references: [id])
  job    Job     @relation(fields: [jobId], references: [id])
  resume Resume? @relation(fields: [resumeId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, jobId])
}

// ================= VOTE =================

model Vote {
  id     String   @id @default(uuid())
  userId String
  jobId  String
  type   VoteType

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
}

// ================= COMMENT =================

model Comment {
  id       String  @id @default(uuid())
  userId   String
  jobId    String
  content  String
  parentId String?

  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies Comment[] @relation("CommentReplies")

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())
}

// ================= REPORT =================

model Report {
  id      String       @id @default(uuid())
  userId  String
  jobId   String
  reason  ReportReason
  message String?

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())
}

// ================= RESUME =================

model Resume {
  id      String @id @default(uuid())
  userId  String
  fileUrl String

  user     User            @relation(fields: [userId], references: [id])
  analysis ResumeAnalysis?

  createdAt    DateTime      @default(now())
  applications Application[]
}

// ================= RESUME ANALYSIS =================

model ResumeAnalysis {
  id       String @id @default(uuid())
  resumeId String @unique

  extractedSkills String[]
  experienceYears Int?
  score           Float?

  resume Resume @relation(fields: [resumeId], references: [id])
}

// ================= JOB MATCH =================

model JobMatch {
  id     String @id @default(uuid())
  userId String
  jobId  String

  matchScore    Float
  missingSkills String[]

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
}

// ================= NOTIFICATION =================

model Notification {
  id      String  @id @default(uuid())
  userId  String
  title   String
  message String
  isRead  Boolean @default(false)

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ================= SAVED JOB =================

model SavedJob {
  id     String @id @default(uuid())
  userId String
  jobId  String

  user User @relation(fields: [userId], references: [id])
  job  Job  @relation(fields: [jobId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, jobId])
}

// ================= CHAT ROOM =================

model ChatRoom {
  id          String  @id @default(uuid())
  recruiterId String
  candidateId String
  jobId       String?

  recruiter User @relation("RecruiterChats", fields: [recruiterId], references: [id])
  candidate User @relation("CandidateChats", fields: [candidateId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recruiterId, candidateId, jobId])
}

// ================= MESSAGE =================

model Message {
  id       String  @id @default(uuid())
  chatId   String
  senderId String
  content  String
  isRead   Boolean @default(false)

  chat   ChatRoom @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User     @relation("SentMessages", fields: [senderId], references: [id])

  createdAt DateTime @default(now())
}
